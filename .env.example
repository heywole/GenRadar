# Copy this file to .env.local and fill in your real values
# NEVER commit .env.local to git

# Supabase — get from: app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# GenLayer — get contract address after running: npm run contract:deploy
GENLAYER_CONTRACT_ADDRESS=0x-your-deployed-contract-address
GENLAYER_PRIVATE_KEY=0x-your-wallet-private-key
